      "Use the reference site for structure and density only; create a distinct brand system."
    ],
    "avoid_styles": [
      "verbatim copied reference HTML",
      "reference logos",
      "reference product images",
      "reference text"
    ]
  },
  "commerce": {
    "currency": "USD",
    "shipping_origin": "",
